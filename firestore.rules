rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 1. Users Collection
    match /users/{userId} {
      // Allow public read for login lookup
      allow read: if true;
      
      // Admins can delete users. 
      // Users can create their own profile if it doesn't exist.
      allow create: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      allow delete: if isAdmin();
      
      // Users can update their own data, but not their role or ID
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }
  }
}
